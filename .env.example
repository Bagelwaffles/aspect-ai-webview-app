# ============================================================================
# ASPECT MARKETING SOLUTIONS - Environment Variables Reference
# ============================================================================
# Copy this file to .env.local and fill in all values marked as REQUIRED
# 
# SECURITY WARNING: Never commit .env.local to version control
# Never share secret keys - rotate them immediately if exposed
# ============================================================================

# APP CONFIGURATION
# ============================================================================
# Required: Public URL where app is hosted
NEXT_PUBLIC_APP_URL=https://vo.aspectmarketingsolutions.app
NEXT_PUBLIC_APP_NAME=Aspect Marketing Solutions

# N8N WORKFLOW AUTOMATION
# ============================================================================
# Required: Base URL of n8n instance (with https://)
N8N_BASE_URL=https://flow.aspectmarketingsolutions.app

# Required: Webhook path for n8n to receive requests
N8N_WEBHOOK_PATH=/webhook/vo-app

# Required: Secret token for webhook authentication
# Must match the secret configured in n8n workflow
# Generate: openssl rand -base64 32
N8N_WEBHOOK_SECRET=your-secure-webhook-secret-here

# RELEVANCE AI INTEGRATION
# ============================================================================
# Required: API key for Relevance AI
# Format: sk-[base64-encoded-value]
# Get from: https://hub.relevanceai.com/settings/api-keys
RELEVANCE_API_KEY=sk-your-api-key-here

# Required: Auth token combining project ID and API key
# Format: [project-id]:[api-key]
RELEVANCE_AUTH_TOKEN=project-id:sk-your-api-key-here

# Required: Project ID for Relevance AI
# Get from: https://hub.relevanceai.com/settings
RELEVANCE_PROJECT_ID=your-project-id-here

# Required: Region code for Relevance AI
# Common values: us-west-2, eu-west-1, ap-southeast-1, etc.
RELEVANCE_REGION=us-west-2

# STRIPE PAYMENT PROCESSING
# ============================================================================
# Required: Stripe Secret Key for server-side operations
# DEVELOPMENT: Use sk_test_* key from Stripe dashboard
# PRODUCTION: Use sk_live_* key from Stripe dashboard
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-test-key-here

# Required: Stripe Price ID for subscription product
# Get from: https://dashboard.stripe.com/prices
# Format: price_[alphanumeric]
STRIPE_PRICE_ID=price_your-price-id-here

# Required: Stripe Webhook Signing Secret
# Get from: https://dashboard.stripe.com/webhooks
# Used to validate webhook signatures from Stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# PRINTIFY INTEGRATION (Print-on-Demand)
# ============================================================================
# Required: API key for Printify platform
# Get from: https://app.printify.com/app/account/api-access
PRINTIFY_API_KEY=your-printify-api-key-here

# AI MODELS & SERVICES
# ============================================================================
# Optional: OpenAI API key (if using OpenAI models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: OpenRouter API key (if using OpenRouter models)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk_or_your-openrouter-key-here

# Optional: Grok/xAI API key (for Grok chat integration)
# Get from: https://console.groq.com/keys
GROK_API_KEY=your-grok-api-key-here

# DATABASE & PERSISTENCE
# ============================================================================
# Optional: PostgreSQL connection string (if using credits/user data)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/aspect_db

# DEPLOYMENT & MONITORING
# ============================================================================
# Optional: Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Optional: Environment identifier (development, staging, production)
NODE_ENV=development

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. STRIPE SETUP:
#    - Go to https://dashboard.stripe.com/apikeys
#    - Copy Secret Key (sk_test_... for development)
#    - Configure webhook at: https://dashboard.stripe.com/webhooks
#    - Webhook endpoint: https://yo.aspectmarketingsolutions.app/api/billing/webhook
#    - Listen to: charge.succeeded, invoice.payment_succeeded
#
# 2. N8N SETUP:
#    - Deploy n8n using Docker Compose (see README.md)
#    - Create webhook workflow at: /webhook/vo-app
#    - Generate webhook secret: openssl rand -base64 32
#    - Configure actions: status.ping, relevance.ask.app, credits.use, credits.add
#
# 3. RELEVANCE AI SETUP:
#    - Sign up at https://hub.relevanceai.com
#    - Create/deploy AI agents (AspectBot, Aspect AGI Commander)
#    - Get API key and project ID from account settings
#    - Test with: curl https://api.relevanceai.com/health
#
# 4. PRINTIFY SETUP:
#    - Connect Printify account to your shop
#    - Get API key from API access page
#    - Test with: curl https://api.printify.com/v1/shops -H "Authorization: Bearer YOUR_KEY"
#
# 5. LOCAL DEVELOPMENT:
#    - Copy this file: cp .env.example .env.local
#    - Fill in all REQUIRED values (use test keys for Stripe/etc)
#    - Run: pnpm dev
#    - Test endpoints: curl http://localhost:3000/api/health
#
# 6. VERCEL DEPLOYMENT:
#    - Go to Vercel project settings
#    - Add all environment variables from this file
#    - Use production keys for: STRIPE_*, RELEVANCE_*, PRINTIFY_*
#    - Deploy: git push origin main
#
# ============================================================================
